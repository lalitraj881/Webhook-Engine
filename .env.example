# ================================================
# Webhook Automation Engine — Environment Variables
# Copy this file as .env in the backend/ directory
# ================================================

# ---- MongoDB ----
MONGODB_URI=mongodb://localhost:27017/webhook-engine

# ---- Redis (used by BullMQ for job queues and idempotency) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Application ----
PORT=3000
NODE_ENV=development

# ---- Frontend ----
FRONTEND_URL=http://localhost:5173

# ---- Webhook Security ----
# Set to 'true' to require HMAC-SHA256 signatures on all incoming webhooks.
# When false (default), webhooks without signatures are allowed through.
# In production, this should always be 'true'.
WEBHOOK_SIGNATURE_REQUIRED=false

# ---- Frontend (Vite) ----
# Used by the frontend to connect to the backend API.
# Set this in the frontend/.env file or as a Docker environment variable.
VITE_API_URL=http://localhost:3000
